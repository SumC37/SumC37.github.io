doctype html
html(lang=config.language)
    head
        meta(charset='UTF-8')
        meta(http-equiv="X-UA-Compatible" content="IE=edge")
        meta(name="viewport" content="width=device-width, initial-scale=1, maximum-scale=5")
        title=config.title
        meta(name="author" content=config.author)
        !=favicon_tag(config.favicon || theme.favicon || '/favicon.ico')
        each item in theme.CDN_USE.css
            link(rel='stylesheet', href=url_for(item))
    body
        header#page_header
            include ./header.pug
        main#page_main
            include ./side-card.pug
            block content
        include ./mobile-nav.pug
        footer#page_footer
            include ./footer.pug
        each item in theme.CDN_USE.js
            != '<script src="' + url_for(item) + '"></script>'
        if config.mermaid && config.mermaid.enable
            != '<script src="https://cdn.jsdelivr.net/npm/mermaid@' + (config.mermaid.version || '10.9.1') + '/dist/mermaid.min.js"></script>'
            script.
                (function() {
                  if (!window.mermaid) return;
                  var options = !{JSON.stringify(config.mermaid.options || { startOnLoad: true })};
                  window.mermaid.initialize(options);
                  if (typeof window.mermaid.run === 'function') {
                    window.mermaid.run({ querySelector: 'pre.mermaid' });
                  }
                })();