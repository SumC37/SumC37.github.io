//customize your own CSS for page display

// Masonry / Waterfall cards (used on Home directory & /blog/)
.page
	.masonry
		padding-left 1.2rem
		padding-right 1.2rem
		column-count 3
		column-gap 1.6rem

	@media (max-width: 56em)
		.masonry
			column-count 2

	@media (max-width: 34em)
		.masonry
			column-count 1

.masonry-item
	break-inside avoid
	-webkit-column-break-inside avoid
	display inline-block
	width 100%
	margin 0 0 1.6rem

.masonry-card
	border 1px solid #f2f3f3
	border-radius 4px
	background #fff
	padding 1.2rem 1.4rem

.masonry-title
	margin 0 0 .6rem
	font-size 2.2rem
	a
		text-decoration none
		color #000
		&:hover
			color #000

.masonry-meta
	color #7a8288
	font-size 1.4rem
	margin-bottom .8rem

.masonry-excerpt
	p:last-child
		margin-bottom 0